{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "app-map.jsx",
              "app-news.jsx",
              "app.jsx",
              "components/badges/**",
              "components/cards/**",
              "components/core/**",
              "components/feedback/**",
              "components/filters/**",
              "components/forms/**",
              "components/map/**",
              "components/quote/**",
              "components/sections/**",
              "sections2.jsx",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Playfair Display|IBM Plex Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Playfair Display, IBM Plex Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIScoreBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|reason|method|size|style|key|ref|className|style|children)$/]",
        "message": "<AIScoreBadge> doesn't accept that prop. Declared props: score, reason, method, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIScoreBadge'] > JSXAttribute[name.name='method'] > Literal[value!=/^(?:rule|llm|hybrid)$/]",
        "message": "<AIScoreBadge> method must be one of 'rule' | 'llm' | 'hybrid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIScoreBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<AIScoreBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|loading|disabled|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, loading, disabled, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|cta|secondary|outline|outline-inverse|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'cta' | 'secondary' | 'outline' | 'outline-inverse' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CaseStudyCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|industry|result|image|onDetail|style|key|ref|className|style|children)$/]",
        "message": "<CaseStudyCard> doesn't accept that prop. Declared props: brand, industry, result, image, onDetail, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:resultCount|onClear|children|style|key|ref|className|style|children)$/]",
        "message": "<FilterBar> doesn't accept that prop. Declared props: resultCount, onClear, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onClick|onRemove|children|style|key|ref|className|style|children)$/]",
        "message": "<FilterChip> doesn't accept that prop. Declared props: active, onClick, onRemove, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|error|hint|htmlFor|children|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, required, error, hint, htmlFor, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='LocationCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|type|city|size|price|status|score|reason|image|selected|unavailable|onSelect|onAdd|style|key|ref|className|style|children)$/]",
        "message": "<LocationCard> doesn't accept that prop. Declared props: name, type, city, size, price, status, score, reason, image, selected, unavailable, onSelect, onAdd, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LocationCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:available|soon|booked)$/]",
        "message": "<LocationCard> status must be one of 'available' | 'soon' | 'booked'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapMarker'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|count|style|key|ref|className|style|children)$/]",
        "message": "<MapMarker> doesn't accept that prop. Declared props: state, count, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapMarker'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:default|hover|selected|cluster)$/]",
        "message": "<MapMarker> state must be one of 'default' | 'hover' | 'selected' | 'cluster'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuoteTray'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|total|onSubmit|onOpen|fixed|style|key|ref|className|style|children)$/]",
        "message": "<QuoteTray> doesn't accept that prop. Declared props: count, total, onSubmit, onOpen, fixed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|style|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: status, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:available|soon|booked)$/]",
        "message": "<StatusPill> status must be one of 'available' | 'soon' | 'booked'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|title|message|onClose|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: kind, title, message, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:success|error|info)$/]",
        "message": "<Toast> kind must be one of 'success' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustStats'] > JSXAttribute > JSXIdentifier[name!=/^(?:stats|inverse|style|key|ref|className|style|children)$/]",
        "message": "<TrustStats> doesn't accept that prop. Declared props: stats, inverse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TypeBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<TypeBadge> doesn't accept that prop. Declared props: children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
